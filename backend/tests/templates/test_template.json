{"name": "Test Production Report", "category": "General", "description": "Test template", "content": {"body": "\n                    <html>\n                        <body>\n                            <h1>Test Production Report</h1>\n                            <p>Machine: {{ machine_id }}</p>\n                            <p>Shift: {{ shift }}</p>\n                            <p>Report Type: {{ report_type }}</p>\n                            <h3>Raw Telemetry Data</h3>\n                            <table border=\"1\">\n                                <tr><th>Timestamp</th><th>Parameter</th><th>Value</th><th>Unit</th></tr>\n                                {% for row in data[:50] %}\n                                <tr>\n                                    <td>{{ row.timestamp }}</td>\n                                    <td>{{ row.parameter }}</td>\n                                    <td>{{ row.value }}</td>\n                                    <td>{{ row.unit }}</td>\n                                </tr>\n                                {% endfor %}\n                            </table>\n                        </body>\n                    </html>\n                    "}}