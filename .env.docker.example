# Copy to `.env` (next to docker-compose.yml) and adjust before deploying.
# docker compose automatically reads a .env file in this directory.

# Strong random secret for signing JWTs (REQUIRED in production).
JWT_SECRET=please-change-this-to-a-long-random-string

# Default admin login, seeded on first boot. CHANGE THESE.
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin123

# SA password for the bundled SQL Server (meet complexity rules).
MSSQL_SA_PASSWORD=Scada!Pass2026

# Seed demo data on first boot (1) or start empty (0).
SEED_DEMO_DATA=1

# Where the browser reaches the backend. For a remote host use its public URL,
# e.g. https://scada.example.com (this is baked into the frontend at build time).
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000
